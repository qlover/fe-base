{
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    // "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "node",
    "types": ["react", "jest", "node", "trusted-types", "jest-extended"]
  },
  "include": ["**/__tests__/*"],
  "exclude": ["**/node_modules/*", "**/dist", "**/build"]
}
