{
  "name": "examples/taro-seed",
  "version": "1.0.2",
  "private": true,
  "description": "taro react vite",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "None",
    "framework": "React"
  },
  "scripts": {
    "new": "taro new",
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "build:harmony-hybrid": "taro build --type harmony-hybrid",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch",
    "dev:harmony-hybrid": "npm run build:harmony-hybrid -- --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,types}/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "browserslist": {
    "development": [
      "defaults and fully supports es6-module",
      "maintained node versions"
    ],
    "production": [
      "last 3 versions",
      "Android >= 4.1",
      "ios >= 8"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "none",
    "endOfLine": "lf",
    "printWidth": 80
  },
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@qlover/corekit-bridge": "workspace:*",
    "@qlover/fe-corekit": "workspace:*",
    "@qlover/logger": "workspace:*",
    "@qlover/slice-store-react": "^1.4.2",
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-alipay": "4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-harmony-hybrid": "4.1.11",
    "@tarojs/plugin-platform-jd": "4.1.11",
    "@tarojs/plugin-platform-qq": "4.1.11",
    "@tarojs/plugin-platform-swan": "4.1.11",
    "@tarojs/plugin-platform-tt": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "clsx": "^2.1.1",
    "lodash-es": "^4.17.23",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.1",
    "@brain-toolkit/ts2locales": "^0.4.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@qlover/eslint-plugin": "^2.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-generator": "4.1.11",
    "@tarojs/vite-runner": "4.1.11",
    "@types/lodash-es": "^4.17.12",
    "@types/minimatch": "^5",
    "@types/node": "^25.3.5",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-preset-taro": "4.1.11",
    "@eslint/config-helpers": "^0.3.0",
    "@eslint/js": "^8.57.0",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.1.11",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.4.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react-refresh": "^0.14.0",
    "stylelint": "^16.4.0",
    "stylelint-config-standard": "^38.0.0",
    "tailwindcss": "^4.2.1",
    "terser": "^5.30.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.1",
    "vite": "^4.2.0",
    "weapp-tailwindcss": "^4.10.3"
  }
}
