    "antd": "^5.27.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "inversify": "^7.8.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "next": "^16.1.6",
