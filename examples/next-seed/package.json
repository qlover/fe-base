{
  "name": "examples/next-seed",
  "version": "1.3.2",
  "private": true,
  "description": "Next.js app shell with theme, i18n, and auth",
  "scripts": {
    "dev": "cross-env APP_ENV=localhost next dev --port 3010",
    "dev:staging": "cross-env APP_ENV=staging next dev --port 3010",
    "dev:prod": "cross-env APP_ENV=production next dev --port 3010",
    "dev:turbo": "cross-env APP_ENV=localhost next dev --turbopack --port 3010",
    "build": "cross-env APP_ENV=production NODE_ENV=production next build && next-sitemap",
    "build:staging": "cross-env APP_ENV=staging NODE_ENV=production next build && next-sitemap",
    "build:dev": "cross-env APP_ENV=localhost NODE_ENV=production next build && next-sitemap",
    "start": "next start --port 3011",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "fix": "npm run lint:fix && npm run format",
    "type-check": "tsc --build --force",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@brain-toolkit/antd-theme-override": "^0.0.3",
    "@brain-toolkit/react-kit": "^0.2.2",
    "@heroicons/react": "^2.2.0",
    "@qlover/corekit-bridge": "workspace:*",
    "@qlover/fe-corekit": "workspace:*",
    "@qlover/logger": "workspace:*",
    "@qlover/slice-store-react": "^1.4.2",
    "@qlover/tailwind-theme": "workspace:*",
    "@supabase/postgrest-js": "^2.87.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.2",
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@wrksz/themes": "^0.9.3",
    "antd": "^5.27.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "inversify": "^7.8.1",
    "jsonwebtoken": "^9.0.2",
    "lodash-es": "^4.17.22",
    "next": "^16.1.6",
    "next-intl": "^4.8.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@brain-toolkit/ts2locales": "^0.4.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@qlover/env-loader": "workspace:*",
    "@qlover/eslint-plugin": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@types/lodash-es": "^4.17.12",
    "@types/ms": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^7.0.3",
    "dotenv-expand": "^12.0.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24",
    "npm": ">=10.0.0"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ],
  "prettier": {
    "singleQuote": true,
    "trailingComma": "none",
    "endOfLine": "lf"
  }
}
