{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals", "vite/client"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["./src/*"],
      "@config/*": ["./config/*"],
      "@__tests__/*": ["./__tests__/*"]
    }
  },
  "include": ["src", "config", "__tests__/**/*"],
  "exclude": ["node_modules", "dist"]
}
