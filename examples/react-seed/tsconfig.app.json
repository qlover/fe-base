{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/react-seed.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"],
      "@config/*": ["./config/*"],
      "@qlover/corekit-bridge": ["../../packages/corekit-bridge/src/core"],
      "@qlover/corekit-bridge/*": ["../../packages/corekit-bridge/src/core/*"],
      "@qlover/fe-corekit": ["../../packages/fe-corekit/src"],
      "@qlover/logger": ["../../packages/logger/src"]
    }
  },
  "include": ["src", "config"]
}
