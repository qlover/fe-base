{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "ts-build",
    "tsBuildInfoFile": "ts-build/.tsbuildinfo",
    "strict": true,
    "allowJs": false,
    "checkJs": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "ts-build",
    "__tests__"
  ],
  "references": [
    {
      "path": "../fe-corekit"
    },
    {
      "path": "../logger"
    },
    {
      "path": "../corekit-bridge"
    }
  ]
}