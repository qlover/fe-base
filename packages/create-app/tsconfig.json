{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "ts-build",
    "tsBuildInfoFile": "ts-build/.tsbuildinfo",
    "skipLibCheck": true,
    "downlevelIteration": true,
    "strict": true,
    "allowUnusedLabels": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src/**/*","package.json"],
  "exclude": [
    "dist",
    "node_modules",
    "templates",
    "ts-build",
    "__tests__",
    "__mocks__"
  ],
  "references": [{ "path": "../logger" }, { "path": "../scripts-context" }]
}
