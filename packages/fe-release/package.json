{
  "name": "@qlover/fe-release",
  "description": "A tool for releasing front-end projects, supporting multiple release modes and configurations, simplifying the release process and improving efficiency.",
  "version": "5.0.5",
  "type": "module",
  "private": false,
  "homepage": "https://github.com/qlover/fe-base/tree/master/packages/fe-release",
  "author": "qlover",
  "license": "ISC",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qlover/fe-base.git",
    "directory": "packages/fe-release"
  },
  "files": [
    "bin",
    "dist",
    "package.json",
    "README.md"
  ],
  "keywords": [
    "scripts",
    "release",
    "fe-release"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "fe-release": "dist/cli.js"
  },
  "scripts": {
    "lint": "eslint src --fix",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "build:docs": "fe-code2md -p src -g docs --formatOutput prettier --removePrefix",
    "release": "node dist/cli.js",
    "release-pr": "node dist/cli.js",
    "dryrun:release": "node dist/cli.js --dry-run -V",
    "dryrun:release-pr": "node dist/cli.js --dry-run -V"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/semver": "^7.7.0"
  },
  "dependencies": {
    "@changesets/get-dependents-graph": "^2.1.4",
    "@manypkg/get-packages": "^1.1.3",
    "@octokit/rest": "^21.0.2",
    "@qlover/env-loader": "workspace:*",
    "@qlover/fe-corekit": "workspace:*",
    "@qlover/logger": "workspace:*",
    "@qlover/scripts-context": "workspace:*",
    "commander": "^11.0.0",
    "find-workspaces": "^0.3.1",
    "git-url-parse": "^16.1.0",
    "gitlog": "^5.1.0",
    "lodash-es": "^4.17.22",
    "p-limit": "^6.2.0",
    "semver": "^7.5.4"
  }
}
