{
  "name": "@qlover/fe-corekit",
  "description": "A corekit for frontwork",
  "version": "3.3.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./aborter": {
      "types": "./dist/aborter/index.d.ts",
      "import": "./dist/aborter/index.js",
      "require": "./dist/aborter/index.cjs",
      "default": "./dist/aborter/index.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.js",
      "default": "./dist/common.js"
    },
    "./encrypt": {
      "types": "./dist/encrypt/index.d.ts",
      "import": "./dist/encrypt/index.js",
      "require": "./dist/encrypt/index.cjs",
      "default": "./dist/encrypt/index.js"
    },
    "./executor": {
      "types": "./dist/executor/index.d.ts",
      "import": "./dist/executor/index.js",
      "require": "./dist/executor/index.cjs",
      "default": "./dist/executor/index.js"
    },
    "./request": {
      "types": "./dist/request/index.d.ts",
      "import": "./dist/request/index.js",
      "require": "./dist/request/index.cjs",
      "default": "./dist/request/index.js"
    },
    "./serializer": {
      "types": "./dist/serializer/index.d.ts",
      "import": "./dist/serializer/index.js",
      "require": "./dist/serializer/index.cjs",
      "default": "./dist/serializer/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs",
      "default": "./dist/storage/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qlover/fe-base.git",
    "directory": "packages/fe-corekit"
  },
  "homepage": "https://github.com/qlover/fe-base/tree/master/packages/fe-corekit#readme",
  "keywords": [
    "js-utils",
    "utils",
    "fe-corekit",
    "fe-utils",
    "fe-base"
  ],
  "author": "qlover",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src --fix",
    "build": "tsup",
    "type-check": "tsc --build",
    "build:docs": "fe-code2md --removePrefix -p ./src/index.ts -g ./docs -o ./docs/.output/fe-corekit.json -t ./docs/.output/fe-corekit.tpl.json --formatOutput prettier && rimraf './doc/**/index.md' -g"
  },
  "dependencies": {
    "any-signal": "^4.2.0",
    "axios": "^1.7.9",
    "p-retry": "^7.1.1"
  }
}
