{
  "protectedBranches": ["master"],
  "release": {
    "changesetVersion": {
      "changesetRoot": ".changeset",
      "ignoreNonUpdatedPackages": false,
      "dependencyReleaseTemplate": "- Update dependency **${name}** from `${oldVersion}` to `${newVersion}`"
    },
    "github": {
      "ignoreReleasePaths": ["examples"]
    }
  }
}
